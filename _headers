/assets/favicons/site.webmanifest
  Content-Type: application/manifest+json

/assets/favicons/*.png
  Cache-Control: public, max-age=31536000, immutable

/assets/favicons/*.ico
  Cache-Control: public, max-age=31536000, immutable

/assets/fonts/*.woff2
  Content-Type: font/woff2
  Cache-Control: public, max-age=31536000, immutable
